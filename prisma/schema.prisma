generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://user@localhost:5432/viadb?schema=public"
}

model Meal {
  id             Int       @id @default(autoincrement())
  name           String
  category       String
  description    String
  pricePerPerson Int
  prepTime       String
  serves         String
  spiceLevel     String
  bookings       Booking[]
}

model Booking {
  id           Int      @id @default(autoincrement())
  customerName String
  email        String
  city         String
  guests       Int
  eventDate    DateTime
  notes        String
  createdAt    DateTime @default(now())
  mealId       Int
  meal         Meal     @relation(fields: [mealId], references: [id])
}
